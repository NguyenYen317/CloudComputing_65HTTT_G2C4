<!DOCTYPE html>
<html>

<head>
    <title>Todo Cloud App</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <style>
        .todo-card {
            transition: opacity 0.2s ease, background-color 0.2s ease;
        }

        .todo-card.completed {
            opacity: 0.45;
            background-color: #f1f3f5;
        }

        .todo-text {
            overflow-wrap: anywhere;
        }
    </style>
</head>

<body class="bg-light">

<div class="container mt-5">
    <div class="card shadow p-4">
        <div class="d-flex justify-content-between align-items-center gap-3 mb-4">
            <h1 class="m-0">
                ☁️ Todo Cloud App
            </h1>

            <div class="d-flex gap-2">
                <button
                    id="loginBtn"
                    class="btn btn-dark"
                    type="button"
                >
                    Đăng nhập Google
                </button>

                <button
                    id="logoutBtn"
                    class="btn btn-secondary"
                    type="button"
                    style="display:none;"
                >
                    Đăng xuất
                </button>
            </div>
        </div>

        <h5 id="userName" class="mb-4 text-primary"></h5>

        <p id="authNotice" class="text-muted mb-0">
            Vui lòng đăng nhập Google để xem todo list.
        </p>

        <form id="addTodoForm" action="/add" method="POST" class="d-none gap-2 mb-4">
            <input
                id="todoInput"
                type="text"
                name="todo"
                class="form-control"
                placeholder="Nhập công việc..."
                required
            >

            <button class="btn btn-primary" type="submit">
                Thêm
            </button>
        </form>

        <div id="todoList" class="d-none"></div>
    </div>
</div>

<script id="initialTodosData" type="application/json"><%- JSON.stringify(todos) %></script>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";

import {
    getAuth,
    GoogleAuthProvider,
    signInWithPopup,
    signOut,
    onAuthStateChanged
} from "https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js";

const firebaseConfig = {
    apiKey: "AIzaSyBvXdNoGdeLwGjuAC6SKYnjoOagMAHArZg",
    authDomain: "todo-cloud-app-c0df9.firebaseapp.com",
    projectId: "todo-cloud-app-c0df9",
    storageBucket: "todo-cloud-app-c0df9.firebasestorage.app",
    messagingSenderId: "1038004562809",
    appId: "1:1038004562809:web:1ff88299633ec31d995da8"
};

const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const provider = new GoogleAuthProvider();

provider.setCustomParameters({
    prompt: 'select_account'
});

const loginBtn = document.getElementById('loginBtn');
const logoutBtn = document.getElementById('logoutBtn');
const userName = document.getElementById('userName');
const authNotice = document.getElementById('authNotice');
const addTodoForm = document.getElementById('addTodoForm');
const todoInput = document.getElementById('todoInput');
const todoList = document.getElementById('todoList');
const initialTodosData = document.getElementById('initialTodosData');
let isLoggedIn = false;
let latestTodos = JSON.parse(initialTodosData.textContent || '[]');

function escapeHtml(value) {
    return String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
}

function renderTodos(todos) {
    latestTodos = todos;

    if (!isLoggedIn) {
        todoList.innerHTML = '';
        return;
    }

    if (!todos.length) {
        todoList.innerHTML = '<p class="text-muted mb-0">Chưa có todo nào.</p>';
        return;
    }

    todoList.innerHTML = todos.map((todo) => {
        const safeText = escapeHtml(todo.text);
        const completedClass = todo.completed ? ' completed' : '';
        const textHtml = todo.completed ? `<s>${safeText}</s>` : safeText;

        return `
            <div class="card todo-card mb-3${completedClass}" data-id="${todo.id}">
                <div class="card-body">
                    <div class="view-mode d-flex justify-content-between align-items-center gap-3">
                        <div class="todo-text flex-grow-1">${textHtml}</div>

                        <div class="d-flex gap-2">
                            <button class="btn btn-success complete-btn" type="button">
                                ${todo.completed ? 'Undo' : 'Done'}
                            </button>

                            <button class="btn btn-warning edit-btn" type="button">
                                Sửa
                            </button>

                            <button class="btn btn-danger delete-btn" type="button">
                                Xóa
                            </button>
                        </div>
                    </div>

                    <form class="edit-mode d-none d-flex gap-2">
                        <input
                            class="form-control edit-input"
                            name="todo"
                            value="${safeText}"
                            required
                        >

                        <button class="btn btn-primary" type="submit">
                            Lưu
                        </button>

                        <button class="btn btn-outline-secondary cancel-edit-btn" type="button">
                            Hủy
                        </button>
                    </form>
                </div>
            </div>
        `;
    }).join('');
}

async function postForm(url, body) {
    const response = await fetch(url, {
        method: 'POST',
        headers: {
            'Accept': 'application/json',
            'Content-Type': 'application/x-www-form-urlencoded'
        },
        body
    });

    if (!response.ok) {
        throw new Error(await response.text());
    }
}

loginBtn.addEventListener('click', async () => {
    try {
        await signInWithPopup(auth, provider);
    } catch (error) {
        console.error(error);
    }
});

logoutBtn.addEventListener('click', async () => {
    await signOut(auth);
});

onAuthStateChanged(auth, (user) => {
    if (user) {
        isLoggedIn = true;
        userName.innerHTML = `👋 Xin chào ${escapeHtml(user.displayName)}`;
        loginBtn.style.display = 'none';
        logoutBtn.style.display = 'block';
        authNotice.classList.add('d-none');
        addTodoForm.classList.remove('d-none');
        addTodoForm.classList.add('d-flex');
        todoList.classList.remove('d-none');
        renderTodos(latestTodos);
    } else {
        isLoggedIn = false;
        userName.innerHTML = '';
        loginBtn.style.display = 'block';
        logoutBtn.style.display = 'none';
        authNotice.classList.remove('d-none');
        addTodoForm.classList.add('d-none');
        addTodoForm.classList.remove('d-flex');
        todoList.classList.add('d-none');
        todoList.innerHTML = '';
    }
});

addTodoForm.addEventListener('submit', async (event) => {
    event.preventDefault();

    const text = todoInput.value.trim();

    if (!text) {
        return;
    }

    await postForm('/add', new URLSearchParams({ todo: text }));
    todoInput.value = '';
});

todoList.addEventListener('click', async (event) => {
    const card = event.target.closest('.todo-card');

    if (!card) {
        return;
    }

    const id = card.dataset.id;

    if (event.target.closest('.complete-btn')) {
        await postForm(`/complete/${id}`, new URLSearchParams());
        return;
    }

    if (event.target.closest('.delete-btn')) {
        await postForm(`/delete/${id}`, new URLSearchParams());
        return;
    }

    if (event.target.closest('.edit-btn')) {
        card.querySelector('.view-mode').classList.add('d-none');
        card.querySelector('.edit-mode').classList.remove('d-none');
        card.querySelector('.edit-input').focus();
        return;
    }

    if (event.target.closest('.cancel-edit-btn')) {
        card.querySelector('.edit-mode').classList.add('d-none');
        card.querySelector('.view-mode').classList.remove('d-none');
    }
});

todoList.addEventListener('submit', async (event) => {
    const form = event.target.closest('.edit-mode');

    if (!form) {
        return;
    }

    event.preventDefault();

    const card = form.closest('.todo-card');
    const id = card.dataset.id;
    const text = form.querySelector('.edit-input').value.trim();

    if (!text) {
        return;
    }

    await postForm(`/edit/${id}`, new URLSearchParams({ todo: text }));
});

renderTodos(latestTodos);

const events = new EventSource('/events');

events.onmessage = (event) => {
    renderTodos(JSON.parse(event.data));
};

events.onerror = (error) => {
    console.error(error);
};
</script>

</body>
</html>
